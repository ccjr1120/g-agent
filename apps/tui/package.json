{
  "name": "@g-agent/tui",
  "version": "0.1.0",
  "description": "G-Agent terminal UI",
  "type": "module",
  "bin": {
    "g-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.tsx --outfile ./dist/cli.js --target bun --format esm --packages external --banner \"#!/usr/bin/env bun\"",
    "dev": "bun ./src/cli.tsx",
    "start": "bun ./dist/cli.js"
  },
  "dependencies": {
    "@g-agent/agent": "workspace:*",
    "@g-agent/config": "workspace:*",
    "@g-agent/shared": "workspace:*",
    "ink": "^7.1.0",
    "ink-stream-markdown": "^0.0.8",
    "react": "^19.2.7",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "typescript": "^5.7.2"
  }
}
